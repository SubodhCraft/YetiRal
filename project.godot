[layer_names]

3d_physics/layer_1="Environment"
3d_physics/layer_2="Player"
3d_physics/layer_3="PlayerAndEnv"
3d_physics/layer_4="Hazards"
3d_physics/layer_8="Triggers"

[physics]

common/physics_ticks_per_second=90
3d/physics_engine="Jolt Physics"
3d/solver/position_iterations=12
3d/solver/velocity_iterations=12

[rendering]

rendering_device/driver.windows="d3d12"
